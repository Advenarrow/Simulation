<div class="arch-page">
  <div class="learn-title">🏗 System Architecture</div>
  <div class="learn-sub">Layer-by-layer breakdown of RescueNet's design</div>

  <div class="arch-flow">
    <div class="arch-layer" style="border-color:var(--accent2)">
      <div class="arch-icon">📱</div>
      <div>
        <div class="arch-name" style="color:var(--accent2)">Layer 1 — User Device (Input)</div>
        <div class="arch-desc">
          The victim's Android phone runs the <b>RescueNet app</b>. It collects GPS coordinates every 5 seconds, listens for voice input, monitors battery and signal levels, and generates the SOS packet. Works completely offline. The SOS packet is an encrypted 200-byte payload containing: victim ID, GPS, timestamp, emergency type, voice-to-text message, battery level, and hop counter. Even a ₹4000 Android phone can run this.
        </div>
        <div class="arch-tags"><span class="tag red">Android App</span><span class="tag red">Offline-first</span><span class="tag red">AES-128 Encrypted</span><span class="tag red">Offline STT</span></div>
      </div>
    </div>

    <div class="arch-arrow">↓</div>

    <div class="arch-layer" style="border-color:var(--accent4)">
      <div class="arch-icon">🔀</div>
      <div>
        <div class="arch-name" style="color:var(--accent4)">Layer 2 — Multi-Protocol Transmission</div>
        <div class="arch-desc">
          This is RescueNet's core innovation. The app runs a <b>channel priority engine</b> that simultaneously scans for: (1) Bluetooth mesh peers, (2) LoRa node beacons, (3) 2G signal strength, (4) Wi-Fi hotspots. It selects the fastest available channel automatically. If all fail, Emergency Override broadcasts on all channels simultaneously at maximum power. Channel switching takes under 2 seconds.
        </div>
        <div class="arch-tags"><span class="tag cyan">BLE Mesh</span><span class="tag orange">LoRa 868MHz</span><span class="tag purple">2G SMS</span><span class="tag red">Override Broadcast</span></div>
      </div>
    </div>

    <div class="arch-arrow">↓</div>

    <div class="arch-layer" style="border-color:var(--lora)">
      <div class="arch-icon">📡</div>
      <div>
        <div class="arch-name" style="color:var(--lora)">Layer 3 — LoRa Node Network (Infrastructure)</div>
        <div class="arch-desc">
          Solar-powered LoRa nodes (using ESP32 + SX1276 chip) are installed at key points: village entrances, forest trailheads, hilltops, river crossings. Each node costs ₹1200–₹1800 and runs for months on a small solar panel + battery. They receive SOS from both Bluetooth and LoRa, store it if the gateway is unreachable, and retransmit when connection is restored. Nodes also relay between each other — forming a <b>LoRaWAN backbone</b> across the entire region.
        </div>
        <div class="arch-tags"><span class="tag orange">ESP32+SX1276</span><span class="tag orange">Solar Powered</span><span class="tag orange">LoRaWAN</span><span class="tag orange">₹1500/node</span><span class="tag orange">Store & Forward</span></div>
      </div>
    </div>

    <div class="arch-arrow">↓</div>

    <div class="arch-layer" style="border-color:var(--accent3)">
      <div class="arch-icon">🔗</div>
      <div>
        <div class="arch-name" style="color:var(--accent3)">Layer 4 — Gateway Node</div>
        <div class="arch-desc">
          The gateway is the bridge between the offline emergency network and the internet. It can be: a phone at the edge of network coverage, a LoRa base station with a 4G SIM, or even a school/panchayat office computer. The gateway receives packets from all sources (Bluetooth, LoRa, SMS), deduplicates them (in case all three channels delivered the same SOS), decrypts, validates, and pushes to the cloud server via HTTPS API. Average upload time: 0.3 seconds.
        </div>
        <div class="arch-tags"><span class="tag green">4G/Wi-Fi</span><span class="tag green">De-duplication</span><span class="tag green">HTTPS API</span><span class="tag green">Multi-source</span></div>
      </div>
    </div>

    <div class="arch-arrow">↓</div>

    <div class="arch-layer" style="border-color:var(--accent)">
      <div class="arch-icon">☁</div>
      <div>
        <div class="arch-name" style="color:var(--accent)">Layer 5 — Cloud Server & Alert Engine</div>
        <div class="arch-desc">
          A lightweight Node.js/Python server (can run on ₹500/month VPS) receives all SOS alerts, stores them in a database, and immediately triggers: (1) SMS alert to all registered rescue volunteers in the area, (2) WhatsApp message to district control room, (3) Email to NDRF/SDRF teams, (4) Web dashboard update. The server also handles SMS-to-web conversion: when a 2G SMS arrives, it parses the 160-byte packet and converts it to a full alert with map link.
        </div>
        <div class="arch-tags"><span class="tag cyan">Node.js</span><span class="tag cyan">SMS Parser</span><span class="tag cyan">WhatsApp API</span><span class="tag cyan">₹500/month</span></div>
      </div>
    </div>

    <div class="arch-arrow">↓</div>

    <div class="arch-layer" style="border-color:var(--accent2)">
      <div class="arch-icon">🚨</div>
      <div>
        <div class="arch-name" style="color:var(--accent2)">Layer 6 — Rescue HQ Dashboard</div>
        <div class="arch-desc">
          District rescue coordinators see a real-time web dashboard showing: all active SOS alerts on a map, victim GPS trail, transmission method used, time elapsed since SOS, estimated rescue time, and responder assignments. The dashboard works on any browser — laptop, tablet, or phone. It also shows which nodes are active/down across the entire network, helping pre-position resources during monsoon or disaster season.
        </div>
        <div class="arch-tags"><span class="tag red">Real-Time Map</span><span class="tag red">Responder Dispatch</span><span class="tag red">Network Health</span><span class="tag red">Any Browser</span></div>
      </div>
    </div>
  </div>

  <div style="margin-top:30px;padding:20px;background:rgba(0,229,255,.05);border:1px solid var(--border);border-radius:8px;font-size:.72rem;line-height:1.9;">
    <b style="color:var(--accent);font-family:'Syne',sans-serif;font-size:.9rem;">💡 Key Design Principles</b><br><br>
    <b>1. Offline-First:</b> Every layer works without internet. Internet only needed at the very last step (gateway → cloud).<br>
    <b>2. Graceful Degradation:</b> If Mesh fails → LoRa. If LoRa fails → 2G. If 2G fails → Override. The system never gives up.<br>
    <b>3. Zero User Training:</b> One button (SOS) is all victims need. The system handles all routing decisions automatically.<br>
    <b>4. Low Cost at Scale:</b> A 50 km² forest zone needs ~8 LoRa nodes (₹12,000 total) + free mesh + ₹500/month server.<br>
    <b>5. Existing Infrastructure:</b> Uses villagers' own phones as relay nodes. No new towers. No new cables. No permissions needed.
  </div>
</div>
</div>

<!-- ALERT POPUP -->
<div class="alert-popup" id="alert-popup">
  <span class="alert-close" onclick="closeAlert()">✕</span>
  <div class="alert-title" id="alert-title">✅ RESCUE ALERT RECEIVED</div>
  <div class="alert-body" id="alert-body"></div>
</div>

<script>
  // ── STATE ──
  let mode = 'mesh', scene = 'normal', running = false;
  let sos=0, hops=0, del=0, loraTx=0, overrides=0;
  let recording=false;

  const voices = [
    '"Help! I fell near the waterfall. Leg broken."',
    '"Snake bite near north trail. 2 hikers need help!"',
    '"Flash flood — village road submerged. Evacuate!"',
    '"Lost in forest near Kolli Hills. GPS approx 11.3N."',
    '"Elderly man collapsed near temple. Critical condition."'
  ];
  const locs = ['11.3°N 78.3°E — Kolli Hills','10.9°N 77.1°E — Valparai','11.8°N 79.7°E — Auroville','9.9°N 78.1°E — Cardamom Hills'];

  // ── NAV ──
  function showPage(p) {
    document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.nav-tab').forEach(x=>x.classList.remove('active'));
    document.getElementById('page-'+p).classList.add('active');
    event.target.classList.add('active');
  }

  // ── SETTERS ──
  function setMode(m) {
    mode = m;
    ['mesh','lora','sms','hybrid'].forEach(x=>{
      const b = document.getElementById('mode-'+x);
      if(b) b.classList.toggle('active', x===m);
    });
    document.getElementById('mode-pill').textContent =
      m==='mesh'?'MESH MODE':m==='lora'?'LoRa MODE':m==='sms'?'2G SMS MODE':'HYBRID MODE';
  }

  function setScene(s) {
    scene = s;
    ['normal','partial','loraonly','smsonly','total'].forEach(x=>{
      const b=document.getElementById('scene-'+x);
      if(b) b.classList.toggle('active', x===s);
    });
    // reset all nodes
    ['r1','r2','r3'].forEach(id=>{
      document.getElementById('node-'+id).style.opacity='1';
      document.getElementById('dn-'+id).style.opacity='0';
    });
    document.getElementById('sig-pill').textContent = 'NO COVERAGE';
    document.getElementById('map-label').textContent = 'FOREST / HILL ZONE — ZERO NETWORK COVERAGE';

    if(s==='partial'){
      ['r2','r3'].forEach(id=>{
        document.getElementById('node-'+id).style.opacity='0.3';
        document.getElementById('dn-'+id).style.opacity='1';
      });
    } else if(s==='loraonly'){
      ['r1','r2','r3'].forEach(id=>{
        document.getElementById('node-'+id).style.opacity='0.3';
        document.getElementById('dn-'+id).style.opacity='1';
      });
      document.getElementById('map-label').textContent = 'MESH FAILED — LoRa BACKBONE ACTIVE';
    } else if(s==='smsonly'){
      ['r1','r2','r3'].forEach(id=>{
        document.getElementById('node-'+id).style.opacity='0.2';
        document.getElementById('dn-'+id).style.opacity='1';
      });
      document.getElementById('node-lora').style.opacity='0.3';
      document.getElementById('sig-pill').textContent = '2G WEAK';
    } else if(s==='total'){
      ['r1','r2','r3'].forEach(id=>{
        document.getElementById('node-'+id).style.opacity='0.2';
        document.getElementById('dn-'+id).style.opacity='1';
      });
      document.getElementById('node-lora').style.opacity='0.2';
      document.getElementById('sig-pill').textContent = 'TOTAL BLACKOUT';
      document.getElementById('map-label').textContent = '⚠ TOTAL BLACKOUT — OVERRIDE MODE REQUIRED';
    } else {
      document.getElementById('node-lora').style.opacity='1';
    }
  }

  // ── LOG ──
  function addLog(msg, type) {
    const lb = document.getElementById('log-body');
    const d = document.createElement('div');
    d.className = 'log-entry '+(type||'');
    const t = new Date().toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
    d.innerHTML = `<span class="log-time">[${t}]</span> ${msg}`;
    lb.appendChild(d); lb.scrollTop=lb.scrollHeight;
  }
  function clearLog() {
    document.getElementById('log-body').innerHTML='<div class="log-entry" style="color:var(--muted);font-size:.62rem;">Log cleared.</div>';
  }
  function updStats() {
    document.getElementById('s-sos').textContent=sos;
    document.getElementById('s-hops').textContent=hops;
    document.getElementById('s-del').textContent=del;
    document.getElementById('s-lora').textContent=loraTx;
    document.getElementById('s-ovr').textContent=overrides;
  }

  // ── PACKET ANIMATION ──
  function animPkt(x1,y1,x2,y2,color,done) {
    const p=document.getElementById('pkt');
    p.setAttribute('cx',x1); p.setAttribute('cy',y1);
    p.setAttribute('fill',color); p.setAttribute('r',color==='#ff8c00'?9:7);
    p.setAttribute('opacity','1');
    let t0=null, dur=900;
    function s(ts){ if(!t0)t0=ts; const pr=Math.min((ts-t0)/dur,1);
      p.setAttribute('cx',x1+(x2-x1)*pr); p.setAttribute('cy',y1+(y2-y1)*pr);
      if(pr<1) requestAnimationFrame(s); else{p.setAttribute('opacity','0');if(done)done();}
    }
    requestAnimationFrame(s);
  }

  function showP(id,show){ const e=document.getElementById(id); if(e)e.style.opacity=show?'1':'0'; }

  function pulseNode(id) {
    const coords={user:[120,390],r1:[230,290],r2:[360,210],r3:[490,270],gw:[600,150],rescue:[640,390],lora:[200,360]};
    const ring=document.getElementById('range-ring');
    const c=coords[id]; if(!c) return;
    ring.setAttribute('cx',c[0]); ring.setAttribute('cy',c[1]);
    ring.setAttribute('r','0'); ring.setAttribute('opacity','0.8');
    ring.setAttribute('stroke', id==='lora'?'#ff8c00':id==='rescue'?'#ff4d6d':'#00e5ff');
    let t0=null;
    function s(ts){ if(!t0)t0=ts; const pr=Math.min((ts-t0)/700,1);
      ring.setAttribute('r',pr*60); ring.setAttribute('opacity',(1-pr)*0.8);
      if(pr<1) requestAnimationFrame(s);
    }
    requestAnimationFrame(s);
  }

  function loraRangeAnim() {
    const r=document.getElementById('lora-range');
    r.setAttribute('r','0'); r.setAttribute('opacity','0.7');
    let t0=null;
    function s(ts){ if(!t0)t0=ts; const pr=Math.min((ts-t0)/1200,1);
      r.setAttribute('r',pr*180); r.setAttribute('opacity',(1-pr)*0.7);
      if(pr<1) requestAnimationFrame(s); else r.setAttribute('opacity','0');
    }
    requestAnimationFrame(s);
  }

  function resetPaths() {
    ['p1','p2','p3','p4','p-alt1','p-alt2','p-lora','p-sms','p-cloud','ov1','ov2','ov3','ov4','ov5'].forEach(p=>showP(p,false));
    document.getElementById('sms-badge').style.display='none';
    document.getElementById('lora-badge').style.display='none';
    document.getElementById('override-badge').style.display='none';
    document.getElementById('sos-btn').classList.remove('active');
    document.getElementById('lora-btn').classList.remove('active');
    document.getElementById('override-btn').classList.remove('active');
    running=false;
  }

  // ── TRIGGERS ──
  function triggerSOS(voiceMsg) {
    if(running) return;
    running=true; sos++; updStats();
    document.getElementById('sos-btn').classList.add('active');

    const effectiveMode =
      scene==='total' ? 'override' :
      scene==='smsonly' ? 'sms' :
      scene==='loraonly' ? 'lora' :
      (mode==='hybrid') ? (scene==='partial'?'lora':'mesh') :
      mode;

    if(effectiveMode==='lora') runLoRa(voiceMsg);
    else if(effectiveMode==='sms') runSMS(voiceMsg);
    else if(effectiveMode==='override') runOverride(voiceMsg);
    else runMesh(voiceMsg);
  }

  function triggerVoice() {
    if(running||recording) return;
    recording=true;
    const btn=document.getElementById('voice-btn');
    const vt=document.getElementById('vtranscript');
    btn.classList.add('recording');
    btn.innerHTML=`<div class="vbar"><span></span><span></span><span></span><span></span><span></span></div> RECORDING...`;
    vt.style.display='none';
    const msg=voices[Math.floor(Math.random()*voices.length)];
    addLog('🎤 Voice SOS activated — recording...','sos');
    setTimeout(()=>{
      recording=false;
      btn.classList.remove('recording');
      btn.innerHTML='🎤 VOICE SOS';
      vt.style.display='block';
      vt.innerHTML=`<span style="color:var(--muted)">Decoded: </span>${msg}`;
      addLog(`🔊 Speech-to-text decoded: ${msg}`,'sos');
      setTimeout(()=>triggerSOS(msg),400);
    },2500);
  }

  function triggerLoRa() {
    if(running) return;
    running=true; loraTx++; sos++; updStats();
    document.getElementById('lora-btn').classList.add('active');
    runLoRa(null, true);
  }

  function triggerOverride() {
    if(running) return;
    running=true; overrides++; sos++; updStats();
    document.getElementById('override-btn').classList.add('active');
    runOverride(null, true);
  }

  // ── SIMULATIONS ──
  function runMesh(voiceMsg) {
    const C={user:[120,390],r1:[230,290],r2:[360,210],r3:[490,270],gw:[600,150],rescue:[640,390]};
    const N={user:'VICTIM PHONE',r1:'BT RELAY 1',r2:'BT RELAY 2',r3:'BT RELAY 3',gw:'GATEWAY',rescue:'RESCUE HQ'};
    const isPartial = scene==='partial';
    const hopList = isPartial ? [['user','r1'],['r1','gw']] : [['user','r1'],['r1','r2'],['r2','r3'],['r3','gw']];
    const pathIds = isPartial ? ['p-alt1','p-alt2'] : ['p1','p2','p3','p4'];

    const t0=Date.now();
    addLog(`📱 SOS triggered${voiceMsg?' (VOICE)':''} — Bluetooth mesh initiated`,'sos');
    if(voiceMsg) addLog(`🎤 Voice message attached to packet`,'sos');
    if(isPartial) addLog(`⚠ 2 relay nodes offline — finding alternate route...`,'relay');
    addLog(`📦 SOS packet: GPS + ID + timestamp + ${voiceMsg?'voice+':''}emergency code`,'relay');
    pulseNode('user');

    let step=0;
    function nextHop(){
      if(step>=hopList.length){
        showP('p-cloud',true);
        setTimeout(()=>{
          animPkt(C.gw[0],C.gw[1],C.rescue[0],C.rescue[1],'#39ff14',()=>{
            pulseNode('rescue');
            hops+=hopList.length; del++; updStats();
            const lat=((Date.now()-t0)/1000).toFixed(1);
            document.getElementById('s-time').textContent=lat+'s';
            addLog(`✅ DELIVERED to RESCUE HQ via ${hopList.length} mesh hops`,'rescue');
            addLog(`⏱ Total latency: ${lat}s`,'rescue');
            showAlert('✅ MESH DELIVERED', 'Bluetooth Mesh', hopList.length, lat, voiceMsg, 'normal');
            setTimeout(resetPaths,3500);
          });
        },400);
        return;
      }
      const [fr,to]=hopList[step]; const pid=pathIds[step];
      showP(pid,true);
      setTimeout(()=>{
        animPkt(C[fr][0],C[fr][1],C[to][0],C[to][1],'#ffbe00',()=>{
          pulseNode(to);
          addLog(`↗ Hop ${step+1}: ${N[fr]} → ${N[to]} (BLE)`,'relay');
          step++; setTimeout(nextHop,350);
        });
      },200);
    }
    setTimeout(nextHop,600);
  }

  function runLoRa(voiceMsg, direct=false) {
    document.getElementById('lora-badge').style.display='block';
    if(!document.getElementById('lora-btn').classList.contains('active'))
      document.getElementById('lora-btn').classList.add('active');
    loraTx++;
    const t0=Date.now();
    addLog(`📡 LoRa transmission initiated — scanning 865–867 MHz band`,'lora');
    addLog(`📦 Compressing payload → 220 bytes (GPS + emergency code + ID)`,'lora');
    pulseNode('user'); loraRangeAnim();

    setTimeout(()=>{
      addLog(`📡 LoRa NODE detected at 200m — signal strength -95 dBm`,'lora');
      addLog(`🔁 Packet relayed to LoRa backbone — estimated range 8.3km`,'lora');
      showP('p-lora',true);
      setTimeout(()=>{
        animPkt(120,390,600,150,'#ff8c00',()=>{
          pulseNode('gw');
          addLog(`🔗 Gateway received LoRa packet — pushing to cloud`,'gateway');
          showP('p-cloud',true);
          setTimeout(()=>{
            animPkt(600,150,640,390,'#39ff14',()=>{
              pulseNode('rescue');
              hops+=2; del++; updStats();
              const lat=((Date.now()-t0)/1000).toFixed(1);
              document.getElementById('s-time').textContent=lat+'s';
              addLog(`✅ DELIVERED via LoRa — range covered: ~8km`,'rescue');
              addLog(`⏱ Latency: ${lat}s | Power used: ~20mW`,'rescue');
              showAlert('📡 LoRa DELIVERED', 'LoRa Long-Range Radio', 2, lat, voiceMsg, 'lora');
              setTimeout(resetPaths,3500);
            });
          },400);
        });
      },1500);
    },1000);
  }

  function runSMS(voiceMsg) {
    document.getElementById('sms-badge').style.display='block';
    const t0=Date.now();
    addLog(`📱 All mesh channels unavailable — scanning for 2G...`,'sms');
    pulseNode('user');
    setTimeout(()=>{
      addLog(`📶 2G signal found: BSNL roaming (-108 dBm) — very weak but usable`,'sms');
      addLog(`📦 Compressing SOS → 158 bytes (fits in 1 SMS)`,'sms');
      addLog(`🔢 Packet: [VIC:4821|GPS:11.34N78.37E|BATT:43|TYPE:01|TS:${Math.floor(Date.now()/1000)}]`,'sms');
      showP('p-sms',true);
      setTimeout(()=>{
        animPkt(120,390,600,150,'#a855f7',()=>{
          pulseNode('gw');
          addLog(`✉ SMS delivered to gateway server — parsing packet`,'sms');
          addLog(`🔁 Server decoded: GPS mapped, victim ID resolved, alert triggered`,'sms');
          showP('p-cloud',true);
          setTimeout(()=>{
            animPkt(600,150,640,390,'#39ff14',()=>{
              pulseNode('rescue');
              hops+=1; del++; updStats();
              const lat=((Date.now()-t0)/1000).toFixed(1);
              document.getElementById('s-time').textContent=lat+'s';
              addLog(`✅ DELIVERED via 2G SMS fallback`,'rescue');
              addLog(`⏱ Latency: ${lat}s | SMS cost: ₹0.10`,'rescue');
              showAlert('✉ 2G SMS DELIVERED', '2G SMS Fallback', 1, lat, voiceMsg, 'sms');
              setTimeout(resetPaths,3500);
            });
          },400);
        });
      },1400);
    },900);
  }

  function runOverride(voiceMsg, direct=false) {
    document.getElementById('override-badge').style.display='block';
    document.getElementById('override-btn').classList.add('active');
    overrides++;
    const t0=Date.now();
    addLog(`🔴 EMERGENCY OVERRIDE ACTIVATED — ALL CHANNELS BROADCAST`,'override');
    addLog(`⚡ Priority: CRITICAL | Bypassing normal routing protocols`,'override');
    addLog(`📡 Broadcasting simultaneously: BLE + LoRa + 2G + Wi-Fi scan`,'override');
    pulseNode('user');

    // Broadcast all lines
    ['ov1','ov2','ov3','ov4','ov5'].forEach((id,i)=>{
      setTimeout(()=>showP(id,true),i*120);
    });

    const ovTargets=[
      [230,290,'#a855f7','BT RELAY 1 woken by override broadcast'],
      [360,210,'#a855f7','BT RELAY 2 emergency ping received'],
      [490,270,'#a855f7','BT RELAY 3 override signal detected'],
      [600,150,'#a855f7','GATEWAY — override packet received via LoRa'],
      [640,390,'#a855f7','RESCUE HQ — CRITICAL ALERT triggered'],
    ];

    let i=0;
    function next(){
      if(i>=ovTargets.length){
        pulseNode('rescue');
        hops+=5; del++; updStats();
        const lat=((Date.now()-t0)/1000).toFixed(1);
        document.getElementById('s-time').textContent=lat+'s';
        addLog(`🚨 OVERRIDE DELIVERED — All nodes alerted simultaneously`,'override');
        addLog(`🔁 Auto-retry armed: will re-broadcast every 30s until acknowledged`,'override');
        addLog(`⏱ Override latency: ${lat}s`,'override');
        showAlert('🔴 OVERRIDE DELIVERED', 'Emergency Override (All Channels)', 5, lat, voiceMsg, 'override');
        setTimeout(resetPaths,4000);
        return;
      }
      const [x,y,c,msg]=ovTargets[i];
      setTimeout(()=>{
        animPkt(120,390,x,y,c,()=>{
          addLog(`⚡ ${msg}`,'override');
          i++; next();
        });
      },i===0?800:400);
    }
    setTimeout(next,500);
  }

  function showAlert(title, method, h, latency, voiceMsg, type) {
    const p=document.getElementById('alert-popup');
    const loc=locs[Math.floor(Math.random()*locs.length)];
    p.className='alert-popup '+(type==='lora'?'lora-alert':type==='override'?'override-alert':'');
    document.getElementById('alert-title').textContent=title;
    document.getElementById('alert-body').innerHTML=
      `<b>Method:</b> ${method}<br>
      <b>Hops/Channels:</b> ${h}<br>
      <b>Latency:</b> ${latency}s<br>
      <b>Location:</b> ${loc}<br>
      ${voiceMsg?'<b>Voice:</b> '+voiceMsg+'<br>':''}
      <b>Status:</b> Rescue team dispatched 🚁<br>
      <b>ETA:</b> ~${Math.floor(Math.random()*15+5)} minutes`;
    p.classList.add('show');
    setTimeout(()=>p.classList.remove('show'),7000);
  }
  function closeAlert(){ document.getElementById('alert-popup').classList.remove('show'); }

  function nodeInfo(id) {
    const info={
      user:'📱 VICTIM PHONE — BLE 5.0 broadcast + LoRa trigger. Generates 200-byte AES-128 encrypted SOS packet with GPS, voice, battery, hop counter.',
      r1:'📶 BT RELAY 1 — Villager\'s phone. Receives and re-broadcasts SOS via BLE. No internet needed. Range: ~80m per hop.',
      r2:'📶 BT RELAY 2 — Any phone in the area acts as relay. The more people, the stronger the mesh network.',
      r3:'📶 BT RELAY 3 — Final relay before gateway zone. Adds timestamp and validates hop count.',
      lora:'📡 LoRa NODE — Solar + ESP32 + SX1276 chip. 865MHz. Range: 5–15km. Cost: ₹1500. Runs months on solar. Stores SOS if gateway unreachable.',
      gw:'🔗 GATEWAY — First internet point. Receives from BT mesh, LoRa, and SMS. Deduplicates packets. Pushes to cloud via HTTPS API in 0.3s.',
      rescue:'🚨 RESCUE HQ — Real-time dashboard. Shows victim GPS, route taken, transmission method, time elapsed, and assigns responders.'
    };
    addLog(`ℹ ${info[id]||'Unknown node'}`, '');
  }

  // Init
  addLog('RescueNet 2.0 initialized — 4 transmission modes ready.','');
  addLog('Click any node on the map for detailed info.','');
  addLog('Use the "How It Works" tab to understand each technology.','');
</script>
