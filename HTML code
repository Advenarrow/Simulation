<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RescueNet 2.0 — Rural Emergency Communication Simulator</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050d14;
    --panel: #0a1a26;
    --border: #0e3a52;
    --accent: #00e5ff;
    --accent2: #ff4d6d;
    --accent3: #39ff14;
    --accent4: #ffbe00;
    --accent5: #a855f7;
    --accent6: #ff8c00;
    --text: #cde8f5;
    --muted: #4a7a96;
    --lora: #ff8c00;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Share Tech Mono', monospace; min-height: 100vh; overflow-x: hidden; }
  body::before {
    content: ''; position: fixed; inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,229,255,0.012) 2px, rgba(0,229,255,0.012) 4px);
    pointer-events: none; z-index: 9998;
  }

  /* ── HEADER ── */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 24px; border-bottom: 1px solid var(--border);
    background: rgba(10,26,38,0.97); position: sticky; top: 0; z-index: 200;
  }
  .logo { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; letter-spacing: 2px; color: var(--accent); }
  .logo span { color: var(--accent2); }
  .logo-sub { font-size: 0.55rem; color: var(--muted); letter-spacing: 3px; text-transform: uppercase; margin-top: 2px; }
  .hdr-right { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
  .pill { font-size: 0.6rem; padding: 3px 10px; border-radius: 20px; border: 1px solid var(--border); color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }
  .pill.live { border-color: var(--accent3); color: var(--accent3); animation: blink 2s infinite; }
  .pill.lora-pill { border-color: var(--lora); color: var(--lora); }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }

  /* NAV TABS */
  .nav-tabs { display: flex; border-bottom: 1px solid var(--border); background: rgba(10,26,38,0.9); position: sticky; top: 57px; z-index: 199; }
  .nav-tab {
    padding: 10px 22px; font-size: 0.65rem; letter-spacing: 2px; text-transform: uppercase;
    cursor: pointer; color: var(--muted); border-bottom: 2px solid transparent;
    transition: all 0.2s; font-family: 'Syne', sans-serif; font-weight: 700;
  }
  .nav-tab:hover { color: var(--text); }
  .nav-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* PAGES */
  .page { display: none; }
  .page.active { display: block; }

  /* ── SIMULATOR PAGE ── */
  .sim-layout {
    display: grid; grid-template-columns: 270px 1fr 290px;
    height: calc(100vh - 100px);
  }

  .left-panel { border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow-y: auto; }
  .right-panel { border-left: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }

  .psec { border-bottom: 1px solid var(--border); padding: 14px 16px; }
  .psec-title { font-family: 'Syne', sans-serif; font-size: 0.55rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; }

  /* SOS */
  .sos-btn {
    width: 100%; padding: 16px; background: transparent; border: 2px solid var(--accent2);
    color: var(--accent2); font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800;
    letter-spacing: 6px; cursor: pointer; border-radius: 4px; transition: all .2s;
  }
  .sos-btn:hover { background: rgba(255,77,109,.1); box-shadow: 0 0 30px rgba(255,77,109,.3); }
  .sos-btn.active { background: var(--accent2); color: #fff; animation: redpulse .8s infinite; }
  @keyframes redpulse { 0%,100%{box-shadow:0 0 20px rgba(255,77,109,.6)} 50%{box-shadow:0 0 50px rgba(255,77,109,1)} }

  .voice-btn {
    width: 100%; padding: 10px; margin-top: 8px; background: transparent;
    border: 1px solid var(--accent); color: var(--accent);
    font-family: 'Share Tech Mono', monospace; font-size: 0.8rem;
    cursor: pointer; border-radius: 4px; transition: all .2s;
    display: flex; align-items: center; gap: 8px; justify-content: center;
  }
  .voice-btn:hover { background: rgba(0,229,255,.08); }
  .voice-btn.recording { border-color: var(--accent2); color: var(--accent2); animation: redpulse 1s infinite; }
  .vbar { display: flex; gap: 3px; align-items: center; height: 18px; }
  .vbar span { width: 3px; background: var(--accent2); border-radius: 2px; animation: vwave .5s ease-in-out infinite alternate; }
  .vbar span:nth-child(2){animation-delay:.1s} .vbar span:nth-child(3){animation-delay:.2s} .vbar span:nth-child(4){animation-delay:.3s} .vbar span:nth-child(5){animation-delay:.4s}
  @keyframes vwave { from{height:3px} to{height:16px} }
  .vtranscript { margin-top:8px; padding:8px; background:rgba(0,229,255,.05); border:1px solid rgba(0,229,255,.15); border-radius:4px; font-size:.68rem; line-height:1.5; display:none; }

  /* LORA button */
  .lora-btn {
    width: 100%; padding: 10px; margin-top: 8px; background: transparent;
    border: 1px solid var(--lora); color: var(--lora);
    font-family: 'Share Tech Mono', monospace; font-size: 0.8rem;
    cursor: pointer; border-radius: 4px; transition: all .2s;
  }
  .lora-btn:hover { background: rgba(255,140,0,.1); box-shadow: 0 0 20px rgba(255,140,0,.2); }
  .lora-btn.active { background: var(--lora); color: #000; }

  /* Emergency Override */
  .override-btn {
    width: 100%; padding: 10px; margin-top: 8px; background: transparent;
    border: 1px solid var(--accent5); color: var(--accent5);
    font-family: 'Share Tech Mono', monospace; font-size: 0.8rem;
    cursor: pointer; border-radius: 4px; transition: all .2s;
  }
  .override-btn:hover { background: rgba(168,85,247,.1); }
  .override-btn.active { background: var(--accent5); color: #fff; animation: purplepulse 1s infinite; }
  @keyframes purplepulse { 0%,100%{box-shadow:0 0 15px rgba(168,85,247,.5)} 50%{box-shadow:0 0 40px rgba(168,85,247,1)} }

  /* mode/scene buttons */
  .mbtn-group { display: flex; flex-direction: column; gap: 6px; }
  .mbtn {
    padding: 9px 12px; background: transparent; border: 1px solid var(--border);
    color: var(--muted); font-family: 'Share Tech Mono', monospace; font-size: 0.68rem;
    cursor: pointer; border-radius: 4px; transition: all .2s; text-align: left;
    display: flex; align-items: center; gap: 8px;
  }
  .mbtn:hover { border-color: var(--accent); color: var(--accent); }
  .mbtn.active { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,.07); }
  .mbtn .mdot { width: 7px; height: 7px; border-radius: 50%; background: var(--muted); flex-shrink: 0; }
  .mbtn.active .mdot { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
  .mbtn.lora-mode { border-color: var(--lora); color: var(--lora); }
  .mbtn.lora-mode .mdot { background: var(--lora); box-shadow: 0 0 6px var(--lora); }

  /* Legend */
  .legend { display: flex; flex-direction: column; gap: 8px; }
  .leg-item { display: flex; align-items: center; gap: 9px; font-size: 0.65rem; line-height: 1.3; }
  .leg-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }

  /* MAP */
  .map-area {
    position: relative; overflow: hidden;
    background:
      radial-gradient(ellipse at 25% 35%, rgba(0,229,255,.04) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 65%, rgba(57,255,20,.03) 0%, transparent 55%),
      radial-gradient(ellipse at 50% 80%, rgba(255,140,0,.02) 0%, transparent 40%),
      var(--bg);
  }
  .map-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(0,229,255,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,229,255,.04) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .map-top-label {
    position: absolute; top: 12px; left: 50%; transform: translateX(-50%);
    font-size: 0.55rem; letter-spacing: 4px; text-transform: uppercase;
    color: var(--muted); background: var(--bg); padding: 3px 14px;
    border: 1px solid var(--border); border-radius: 20px; white-space: nowrap;
  }
  svg#nmap { width: 100%; height: 100%; position: absolute; inset: 0; }
  .signal-path { stroke-dasharray: 6 4; animation: dashflow 1s linear infinite; }
  @keyframes dashflow { to { stroke-dashoffset: -20; } }
  .lora-path { stroke-dasharray: 10 5; animation: loradash 1.5s linear infinite; }
  @keyframes loradash { to { stroke-dashoffset: -30; } }
  .node-g { cursor: pointer; }
  .node-g:hover circle { filter: brightness(1.5); }

  /* LOG */
  .log-header { padding: 12px 16px; border-bottom: 1px solid var(--border); font-family: 'Syne', sans-serif; font-size: 0.55rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); display: flex; justify-content: space-between; }
  .log-clear { cursor: pointer; color: var(--muted); } .log-clear:hover { color: var(--accent2); }
  .log-body { flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 5px; }
  .log-entry { padding: 7px 9px; border-radius: 3px; font-size: 0.65rem; border-left: 3px solid var(--border); background: rgba(255,255,255,.02); animation: loginanim .3s ease; line-height: 1.4; }
  @keyframes loginanim { from{opacity:0;transform:translateX(8px)} to{opacity:1;transform:none} }
  .log-entry.sos { border-color: var(--accent2); background: rgba(255,77,109,.07); }
  .log-entry.relay { border-color: var(--accent4); background: rgba(255,190,0,.05); }
  .log-entry.gateway { border-color: var(--accent3); background: rgba(57,255,20,.05); }
  .log-entry.sms { border-color: var(--accent5); background: rgba(168,85,247,.05); }
  .log-entry.lora { border-color: var(--lora); background: rgba(255,140,0,.06); }
  .log-entry.rescue { border-color: var(--accent); background: rgba(0,229,255,.05); }
  .log-entry.override { border-color: var(--accent5); background: rgba(168,85,247,.1); }
  .log-time { color: var(--muted); font-size: 0.58rem; }
  .stats-bar { padding: 10px 14px; border-top: 1px solid var(--border); display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .stat { text-align: center; }
  .stat-val { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 800; color: var(--accent); }
  .stat-val.r { color: var(--accent2); } .stat-val.g { color: var(--accent3); } .stat-val.y { color: var(--accent4); } .stat-val.o { color: var(--lora); }
  .stat-lbl { font-size: 0.5rem; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; }

  /* ALERT POPUP */
  .alert-popup {
    position: fixed; top: 110px; right: 310px;
    background: var(--panel); border: 2px solid var(--accent3); border-radius: 8px;
    padding: 14px 18px; max-width: 260px; z-index: 300;
    display: none; animation: popin .4s cubic-bezier(.34,1.56,.64,1);
    box-shadow: 0 0 40px rgba(57,255,20,.3);
  }
  .alert-popup.show { display: block; }
  @keyframes popin { from{opacity:0;transform:scale(.8) translateY(-16px)} to{opacity:1;transform:none} }
  .alert-popup.lora-alert { border-color: var(--lora); box-shadow: 0 0 40px rgba(255,140,0,.3); }
  .alert-popup.override-alert { border-color: var(--accent5); box-shadow: 0 0 40px rgba(168,85,247,.4); }
  .alert-title { font-family: 'Syne', sans-serif; font-size: 0.8rem; font-weight: 700; color: var(--accent3); margin-bottom: 5px; }
  .alert-popup.lora-alert .alert-title { color: var(--lora); }
  .alert-popup.override-alert .alert-title { color: var(--accent5); }
  .alert-body { font-size: 0.67rem; line-height: 1.6; color: var(--text); }
  .alert-close { position: absolute; top: 7px; right: 10px; cursor: pointer; color: var(--muted); }
  .sms-badge { position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%); font-size: 0.58rem; letter-spacing: 2px; color: var(--accent5); background: rgba(168,85,247,.15); border: 1px solid var(--accent5); border-radius: 20px; padding: 3px 10px; display: none; }
  .lora-badge { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); font-size: 0.58rem; letter-spacing: 2px; color: var(--lora); background: rgba(255,140,0,.15); border: 1px solid var(--lora); border-radius: 20px; padding: 3px 10px; display: none; }
  .override-badge { position: absolute; bottom: 64px; left: 50%; transform: translateX(-50%); font-size: 0.58rem; letter-spacing: 2px; color: var(--accent5); background: rgba(168,85,247,.2); border: 1px solid var(--accent5); border-radius: 20px; padding: 3px 10px; display: none; animation: purplepulse 1s infinite; }

  /* scrollbar */
  ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-track { background: var(--bg); } ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* ── LEARN PAGE ── */
  .learn-page { padding: 30px; max-width: 1100px; margin: 0 auto; }
  .learn-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 24px; }
  .learn-card {
    background: var(--panel); border: 1px solid var(--border); border-radius: 8px;
    padding: 22px; transition: border-color .3s;
    position: relative; overflow: hidden;
  }
  .learn-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
  .learn-card.cyan::before { background: var(--accent); }
  .learn-card.orange::before { background: var(--lora); }
  .learn-card.green::before { background: var(--accent3); }
  .learn-card.purple::before { background: var(--accent5); }
  .learn-card.red::before { background: var(--accent2); }
  .learn-card.yellow::before { background: var(--accent4); }
  .learn-card:hover { border-color: var(--muted); }
  .card-icon { font-size: 2rem; margin-bottom: 12px; }
  .card-title { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 800; margin-bottom: 6px; }
  .learn-card.cyan .card-title { color: var(--accent); }
  .learn-card.orange .card-title { color: var(--lora); }
  .learn-card.green .card-title { color: var(--accent3); }
  .learn-card.purple .card-title { color: var(--accent5); }
  .learn-card.red .card-title { color: var(--accent2); }
  .learn-card.yellow .card-title { color: var(--accent4); }
  .card-subtitle { font-size: 0.6rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
  .card-body { font-size: 0.72rem; line-height: 1.8; color: var(--text); }
  .card-body b { color: var(--accent); }
  .spec-table { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 0.65rem; }
  .spec-table td { padding: 5px 8px; border: 1px solid var(--border); }
  .spec-table td:first-child { color: var(--muted); width: 45%; }
  .spec-table td:last-child { color: var(--text); }
  .flow-steps { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
  .flow-step { display: flex; gap: 10px; align-items: flex-start; font-size: 0.68rem; line-height: 1.5; }
  .step-num { width: 20px; height: 20px; border-radius: 50%; background: var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; flex-shrink: 0; color: var(--accent); font-family: 'Syne', sans-serif; font-weight: 700; }
  .tag { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 0.6rem; margin: 2px; }
  .tag.cyan { background: rgba(0,229,255,.15); color: var(--accent); border: 1px solid rgba(0,229,255,.3); }
  .tag.orange { background: rgba(255,140,0,.15); color: var(--lora); border: 1px solid rgba(255,140,0,.3); }
  .tag.green { background: rgba(57,255,20,.15); color: var(--accent3); border: 1px solid rgba(57,255,20,.3); }
  .tag.purple { background: rgba(168,85,247,.15); color: var(--accent5); border: 1px solid rgba(168,85,247,.3); }
  .tag.red { background: rgba(255,77,109,.15); color: var(--accent2); border: 1px solid rgba(255,77,109,.3); }

  .learn-title { font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--accent); }
  .learn-sub { font-size: 0.65rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: 0.68rem; margin-top: 20px; }
  .compare-table th { padding: 10px 12px; background: rgba(0,229,255,.08); border: 1px solid var(--border); font-family: 'Syne', sans-serif; font-weight: 700; color: var(--accent); text-align: left; }
  .compare-table td { padding: 9px 12px; border: 1px solid var(--border); line-height: 1.4; }
  .compare-table tr:hover td { background: rgba(255,255,255,.02); }
  .good { color: var(--accent3); } .mid { color: var(--accent4); } .bad { color: var(--accent2); }

  /* ── ARCHITECTURE PAGE ── */
  .arch-page { padding: 30px; max-width: 900px; margin: 0 auto; }
  .arch-flow { display: flex; flex-direction: column; gap: 12px; margin-top: 24px; }
  .arch-layer {
    background: var(--panel); border: 1px solid var(--border); border-radius: 6px;
    padding: 16px 20px; display: flex; gap: 16px; align-items: flex-start;
  }
  .arch-icon { font-size: 1.8rem; flex-shrink: 0; }
  .arch-name { font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 800; margin-bottom: 4px; }
  .arch-desc { font-size: 0.68rem; line-height: 1.7; color: var(--text); }
  .arch-tags { margin-top: 6px; }
  .arch-arrow { text-align: center; color: var(--muted); font-size: 1.2rem; }
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">Rescue<span>Net</span> <span style="font-size:.8rem;color:var(--accent4)">2.0</span></div>
    <div class="logo-sub">Rural Emergency Communication System — Niral Thiruvizha 3.0 | Problem #35</div>
  </div>
  <div class="hdr-right">
    <div class="pill live">● SIM LIVE</div>
    <div class="pill lora-pill">📡 LoRa ENABLED</div>
    <div class="pill" id="mode-pill">MESH MODE</div>
    <div class="pill" id="sig-pill">NO COVERAGE</div>
  </div>
</header>

<!-- NAV -->
<div class="nav-tabs">
  <div class="nav-tab active" onclick="showPage('sim')">🗺 Simulator</div>
  <div class="nav-tab" onclick="showPage('learn')">📖 How It Works</div>
  <div class="nav-tab" onclick="showPage('arch')">🏗 Architecture</div>
</div>

<!-- ═══════════════════ SIMULATOR PAGE ═══════════════════ -->
<div id="page-sim" class="page active">
<div class="sim-layout">

  <!-- LEFT -->
  <div class="left-panel">

    <div class="psec">
      <div class="psec-title">⚠ Emergency Triggers</div>
      <button class="sos-btn" id="sos-btn" onclick="triggerSOS()">⚠ SOS</button>
      <button class="voice-btn" id="voice-btn" onclick="triggerVoice()">🎤 VOICE SOS</button>
      <div class="vtranscript" id="vtranscript"></div>
      <button class="lora-btn" id="lora-btn" onclick="triggerLoRa()">📡 LoRa LONG-RANGE SOS</button>
      <button class="override-btn" id="override-btn" onclick="triggerOverride()">🔴 EMERGENCY OVERRIDE</button>
    </div>

    <div class="psec">
      <div class="psec-title">📡 Transmission Mode</div>
      <div class="mbtn-group">
        <button class="mbtn active" id="mode-mesh" onclick="setMode('mesh')"><div class="mdot"></div>Bluetooth Mesh Hop</button>
        <button class="mbtn" id="mode-lora" onclick="setMode('lora')"><div class="mdot" style="background:var(--lora)"></div><span style="color:var(--lora)">LoRa Long-Range Radio</span></button>
        <button class="mbtn" id="mode-sms" onclick="setMode('sms')"><div class="mdot"></div>2G SMS Fallback</button>
        <button class="mbtn" id="mode-hybrid" onclick="setMode('hybrid')"><div class="mdot"></div>Hybrid Auto-Select</button>
      </div>
    </div>

    <div class="psec">
      <div class="psec-title">🌐 Network Scenario</div>
      <div class="mbtn-group">
        <button class="mbtn active" id="scene-normal" onclick="setScene('normal')"><div class="mdot"></div>Full Mesh Available</button>
        <button class="mbtn" id="scene-partial" onclick="setScene('partial')"><div class="mdot"></div>2 Relay Nodes Down</button>
        <button class="mbtn" id="scene-loraonly" onclick="setScene('loraonly')"><div class="mdot"></div>Mesh Failed — LoRa Only</button>
        <button class="mbtn" id="scene-smsonly" onclick="setScene('smsonly')"><div class="mdot"></div>All Failed — 2G Only</button>
        <button class="mbtn" id="scene-total" onclick="setScene('total')"><div class="mdot"></div>Total Blackout (Override)</button>
      </div>
    </div>

    <div class="psec">
      <div class="psec-title">🗺 Legend</div>
      <div class="legend">
        <div class="leg-item"><div class="leg-dot" style="background:#00e5ff;box-shadow:0 0 6px #00e5ff"></div>User Phone (SOS Source)</div>
        <div class="leg-item"><div class="leg-dot" style="background:#ffbe00;box-shadow:0 0 6px #ffbe00"></div>BT Relay Node (Mesh Hop)</div>
        <div class="leg-item"><div class="leg-dot" style="background:#ff8c00;box-shadow:0 0 6px #ff8c00"></div>LoRa Node (Long-Range)</div>
        <div class="leg-item"><div class="leg-dot" style="background:#39ff14;box-shadow:0 0 6px #39ff14"></div>Gateway (Internet Access)</div>
